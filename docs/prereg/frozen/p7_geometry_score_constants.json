{
  "heldout_max": 0.10,
  "null_gap_min": 0.10,
  "truth_error_max": 0.40,
  "normalized_margins": [
    "(heldout_max - heldout) / heldout_max",
    "(null_gap - null_gap_min) / null_gap_min",
    "(truth_error_max - truth_error) / truth_error_max"
  ],
  "score": "clip(0.5 + min(normalized_margins), 0, 1)",
